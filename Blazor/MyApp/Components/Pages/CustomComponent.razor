@* Route *@
@page "/intro"

@* HTML (Structure) Code *@
<h3>People</h3>
<ol>
	@foreach (var person in people)
	{
		<li>My name is @person.Name and I am @person.Age years old.</li>
	}
</ol>

@* C# (Logic) Code *@
@code {
	class Person
	{
		public string Name { get; set; }
		public int Age { get; set; }
	}

	// Create some instances of the Person class
	List<Person> people = new List<Person>
	{
		new Person { Name = "Talha Ahmad", Age = 20 },
		new Person { Name = "Rayan Zulfiqar", Age = 20 },
		new Person { Name = "Muhammad Raza", Age = 23 },
		new Person { Name = "Areeb Siddiqui", Age = 20 }
	};
}
